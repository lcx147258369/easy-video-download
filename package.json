{
  "name": "51cg-video",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.34.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "concurrently -k -n server,web -c cyan,magenta \"pnpm --filter @video/server dev\" \"pnpm --filter @video/web dev\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --pretty false"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "concurrently": "^9.2.1",
    "jsdom": "^27.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
